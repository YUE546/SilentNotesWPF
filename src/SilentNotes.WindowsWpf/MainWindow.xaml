<Window x:Class="SilentNotes.WindowsWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SilentNotes.WindowsWpf"
        xmlns:views="clr-namespace:SilentNotes.WindowsWpf.Views"
        xmlns:controls="clr-namespace:SilentNotes.WindowsWpf.Controls"
        Title="SilentNotes"
        Width="1120"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Icon="Resources/app.ico"
        Background="{DynamicResource SilentNotesBackgroundBrush}">
  <Window.InputBindings>
    <KeyBinding Gesture="Ctrl+N" Command="{x:Static local:MainWindow.NewNoteCommand}" />
    <KeyBinding Gesture="Ctrl+S" Command="{x:Static local:MainWindow.SaveNoteCommand}" />
    <KeyBinding Gesture="Ctrl+F" Command="{x:Static local:MainWindow.FocusSearchCommand}" />
    <KeyBinding Gesture="Delete" Command="{x:Static local:MainWindow.DeleteNoteCommand}" />
    <KeyBinding Gesture="Ctrl+B" Command="{x:Static local:MainWindow.BoldCommand}" />
    <KeyBinding Gesture="Ctrl+I" Command="{x:Static local:MainWindow.ItalicCommand}" />
    <KeyBinding Gesture="Ctrl+U" Command="{x:Static local:MainWindow.UnderlineCommand}" />
    <KeyBinding Gesture="Ctrl+Z" Command="{x:Static local:MainWindow.UndoCommand}" />
    <KeyBinding Gesture="Ctrl+Y" Command="{x:Static local:MainWindow.RedoCommand}" />
  </Window.InputBindings>
  <Window.CommandBindings>
    <CommandBinding Command="{x:Static local:MainWindow.NewNoteCommand}" Executed="NewNote_Executed" />
    <CommandBinding Command="{x:Static local:MainWindow.SaveNoteCommand}" Executed="SaveNote_Executed" />
    <CommandBinding Command="{x:Static local:MainWindow.FocusSearchCommand}" Executed="FocusSearch_Executed" />
    <CommandBinding Command="{x:Static local:MainWindow.DeleteNoteCommand}" Executed="DeleteNote_Executed" />
    <CommandBinding Command="{x:Static local:MainWindow.BoldCommand}" Executed="Bold_Executed" />
    <CommandBinding Command="{x:Static local:MainWindow.ItalicCommand}" Executed="Italic_Executed" />
    <CommandBinding Command="{x:Static local:MainWindow.UnderlineCommand}" Executed="Underline_Executed" />
    <CommandBinding Command="{x:Static local:MainWindow.UndoCommand}" Executed="Undo_Executed" />
    <CommandBinding Command="{x:Static local:MainWindow.RedoCommand}" Executed="Redo_Executed" />
  </Window.CommandBindings>
  <DockPanel>
    <Border DockPanel.Dock="Top"
            Height="52"
            Background="{DynamicResource SilentNotesPaperBrush}"
            BorderBrush="{DynamicResource SilentNotesBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="20,0">
      <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="220" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="SilentNotes"
                   Style="{StaticResource AppTitleTextStyle}" />
        <TextBlock Grid.Column="1"
                   Text="本地仓库"
                   Style="{StaticResource SecondaryTextStyle}"
                   VerticalAlignment="Center" />
