      </Grid>
    </Border>

    <controls:StatusStrip x:Name="StatusBar" DockPanel.Dock="Bottom" />

    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="340" />
        <ColumnDefinition Width="1" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <views:SidebarView x:Name="Sidebar" Grid.Column="0" />
      <Border Grid.Column="1" Background="{DynamicResource SilentNotesBorderBrush}" />
      <views:NoteEditorView x:Name="EditorView" Grid.Column="2" />
    </Grid>
  </DockPanel>
</Window>
