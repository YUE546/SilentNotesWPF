<Application x:Class="SilentNotes.WindowsWpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SilentNotes.WindowsWpf.Converters"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Themes/Colors.xaml" />
        <ResourceDictionary Source="Themes/Typography.xaml" />
        <ResourceDictionary Source="Themes/Controls.xaml" />
        <ResourceDictionary Source="Themes/ListStyles.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <converters:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
    </ResourceDictionary>
  </Application.Resources>
</Application>
