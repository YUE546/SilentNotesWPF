<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="ColorSurfaceWindow">#F6F7F9</Color>
  <Color x:Key="ColorSurfacePanel">#EEF1F5</Color>
  <Color x:Key="ColorSurfacePaper">#FFFFFF</Color>
  <Color x:Key="ColorBorderSubtle">#D9DEE7</Color>
  <Color x:Key="ColorTextPrimary">#1F2933</Color>
  <Color x:Key="ColorTextSecondary">#667085</Color>
  <Color x:Key="ColorAccent">#4B6BFB</Color>
  <Color x:Key="ColorAccentHover">#3F5DE0</Color>
  <Color x:Key="ColorAccentSoft">#E9EDFF</Color>
  <Color x:Key="ColorDanger">#B42318</Color>
  <Color x:Key="ColorDangerSoft">#FEE4E2</Color>

  <SolidColorBrush x:Key="SilentNotesBackgroundBrush" Color="{StaticResource ColorSurfaceWindow}" />
  <SolidColorBrush x:Key="SilentNotesPanelBrush" Color="{StaticResource ColorSurfacePanel}" />
  <SolidColorBrush x:Key="SilentNotesPaperBrush" Color="{StaticResource ColorSurfacePaper}" />
  <SolidColorBrush x:Key="SilentNotesBorderBrush" Color="{StaticResource ColorBorderSubtle}" />
  <SolidColorBrush x:Key="SilentNotesTextBrush" Color="{StaticResource ColorTextPrimary}" />
  <SolidColorBrush x:Key="SilentNotesSecondaryTextBrush" Color="{StaticResource ColorTextSecondary}" />
  <SolidColorBrush x:Key="SilentNotesPrimaryBrush" Color="{StaticResource ColorAccent}" />
  <SolidColorBrush x:Key="SilentNotesPrimaryHoverBrush" Color="{StaticResource ColorAccentHover}" />
  <SolidColorBrush x:Key="SilentNotesAccentSoftBrush" Color="{StaticResource ColorAccentSoft}" />
  <SolidColorBrush x:Key="SilentNotesDangerBrush" Color="{StaticResource ColorDanger}" />
  <SolidColorBrush x:Key="SilentNotesDangerSoftBrush" Color="{StaticResource ColorDangerSoft}" />
  <SolidColorBrush x:Key="SilentNotesPrimaryTextBrush" Color="{StaticResource ColorTextPrimary}" />
</ResourceDictionary>
