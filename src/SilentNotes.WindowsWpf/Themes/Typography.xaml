<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <FontFamily x:Key="SilentNotesUiFont">Microsoft YaHei UI, Segoe UI</FontFamily>
  <FontFamily x:Key="SilentNotesMonoFont">Consolas</FontFamily>

  <Style TargetType="{x:Type TextBlock}">
    <Setter Property="FontFamily" Value="{StaticResource SilentNotesUiFont}" />
    <Setter Property="Foreground" Value="{DynamicResource SilentNotesTextBrush}" />
    <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
  </Style>

  <Style x:Key="AppTitleTextStyle" TargetType="{x:Type TextBlock}">
    <Setter Property="FontFamily" Value="{StaticResource SilentNotesUiFont}" />
    <Setter Property="Foreground" Value="{DynamicResource SilentNotesTextBrush}" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style x:Key="SectionTitleTextStyle" TargetType="{x:Type TextBlock}">
    <Setter Property="FontFamily" Value="{StaticResource SilentNotesUiFont}" />
    <Setter Property="Foreground" Value="{DynamicResource SilentNotesTextBrush}" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style x:Key="SecondaryTextStyle" TargetType="{x:Type TextBlock}">
    <Setter Property="FontFamily" Value="{StaticResource SilentNotesUiFont}" />
    <Setter Property="Foreground" Value="{DynamicResource SilentNotesSecondaryTextBrush}" />
    <Setter Property="FontSize" Value="12" />
  </Style>
</ResourceDictionary>
