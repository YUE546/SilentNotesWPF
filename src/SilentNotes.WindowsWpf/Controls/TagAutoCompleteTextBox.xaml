<UserControl x:Class="SilentNotes.WindowsWpf.Controls.TagAutoCompleteTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <TextBox x:Name="InputBox"
             VerticalContentAlignment="Center"
             GotFocus="InputBox_GotFocus"
             LostFocus="InputBox_LostFocus"
             TextChanged="InputBox_TextChanged"
             PreviewKeyDown="InputBox_PreviewKeyDown" />
    <Popup x:Name="SuggestionPopup"
           AllowsTransparency="True"
           PlacementTarget="{Binding ElementName=InputBox}"
           Placement="Bottom"
           MaxHeight="160"
           StaysOpen="False">
      <Border Background="{DynamicResource SilentNotesPaperBrush}"
              BorderBrush="{DynamicResource SilentNotesBorderBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Margin="0,2,0,0">
        <ListBox x:Name="SuggestionList"
                 BorderThickness="0"
                 Background="Transparent"
                 MaxHeight="150"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionChanged="SuggestionList_SelectionChanged">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}"
                         Padding="6,4"
                         FontSize="12"
                         Foreground="{DynamicResource SilentNotesTextBrush}" />
            </DataTemplate>
          </ListBox.ItemTemplate>
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd"
                            Padding="0"
                            Background="Transparent">
                      <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Bd" Property="Background"
                                Value="{DynamicResource SilentNotesAccentSoftBrush}" />
                      </Trigger>
                      <Trigger Property="IsSelected" Value="True">
                        <Setter TargetName="Bd" Property="Background"
                                Value="{DynamicResource SilentNotesAccentSoftBrush}" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ListBox.ItemContainerStyle>
        </ListBox>
      </Border>
    </Popup>
  </Grid>
</UserControl>
