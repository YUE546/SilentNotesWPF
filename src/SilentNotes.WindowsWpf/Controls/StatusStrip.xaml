<UserControl x:Class="SilentNotes.WindowsWpf.Controls.StatusStrip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StatusBar Background="{DynamicResource SilentNotesPaperBrush}"
             BorderBrush="{DynamicResource SilentNotesBorderBrush}"
             BorderThickness="0,1,0,0"
             MinHeight="28">
    <TextBlock x:Name="StatusText"
               Text="正在初始化..."
               Style="{StaticResource SecondaryTextStyle}" />
  </StatusBar>
</UserControl>
