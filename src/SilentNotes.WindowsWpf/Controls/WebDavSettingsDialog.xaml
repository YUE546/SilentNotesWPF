<controls:ThemedDialogWindow x:Class="SilentNotes.WindowsWpf.Controls.WebDavSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SilentNotes.WindowsWpf.Controls"
        Title="设置"
        Width="500"
        MinHeight="520"
        Height="600"
        Background="{DynamicResource SilentNotesBackgroundBrush}">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Text="设置"
               Style="{StaticResource SectionTitleTextStyle}"
               Margin="0,0,0,16" />

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel>

        <!-- WebDAV 同步设置 -->
        <TextBlock Text="WebDAV 同步"
                   FontWeight="Bold"
                   FontSize="13"
                   Margin="0,20,0,8" />

        <Label Content="服务器地址" />
        <TextBox x:Name="ServerUrlTextBox"
                 ToolTip="例如 https://example.com/remote.php/dav/files/user/"
                 TextChanged="Fields_TextChanged" />

        <Label Content="用户名" Margin="0,12,0,0" />
        <TextBox x:Name="UsernameTextBox"
                 TextChanged="Fields_TextChanged" />

        <Label Content="密码" Margin="0,12,0,0" />
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <PasswordBox x:Name="PasswordBox"
                       Grid.Column="0"
                       PasswordChanged="Fields_TextChanged" />
          <TextBox x:Name="PasswordVisibleBox"
                   Grid.Column="0"
                   Visibility="Collapsed"
                   TextChanged="Fields_TextChanged" />
          <Button x:Name="TogglePasswordButton"
                  Grid.Column="1"
                  Content="👁"
                  Width="30"
                  Height="22"
                  Margin="4,0,0,0"
                  Padding="0"
                  ToolTip="显示/隐藏密码"
                  Click="TogglePasswordButton_Click" />
        </Grid>

        <Border MinHeight="48"
                Margin="0,12,0,0"
                Padding="12,10"
                Background="{DynamicResource SilentNotesAccentSoftBrush}"
                CornerRadius="5">
          <TextBlock x:Name="StatusText"
                     Style="{StaticResource SecondaryTextStyle}"
                     TextWrapping="Wrap" />
        </Border>

        <!-- 云加密传输码 -->
        <TextBlock Text="云加密"
                   FontWeight="Bold"
                   FontSize="13"
                   Margin="0,20,0,8" />

        <Label Content="传输码（用于加密/解密云端仓库文件）" />
        <TextBox x:Name="TransferCodeBox"
                 ToolTip="设置一个强密码，用于加密上传到云端的笔记数据
注意：此密码无法找回，请妥善保管" />

        <!-- 自动同步模式 -->
        <TextBlock Text="自动同步"
                   FontWeight="Bold"
                   FontSize="13"
                   Margin="0,20,0,8" />

        <ComboBox x:Name="SyncModeBox"
                  Margin="0,0,0,8"
                  SelectedIndex="0">
          <ComboBoxItem Tag="Never">手动同步</ComboBoxItem>
          <ComboBoxItem Tag="CostFreeInternetOnly">仅网络空闲时</ComboBoxItem>
          <ComboBoxItem Tag="Always">总是</ComboBoxItem>
        </ComboBox>

        <!-- 本地数据文件位置 -->
        <TextBlock Text="本地数据文件"
                   FontWeight="Bold"
                   FontSize="13"
                   Margin="0,20,0,8" />

        <TextBlock Text="数据文件保存位置："
                   Margin="0,0,0,4" />
        <TextBox x:Name="DataDirectoryBox"
                 ToolTip="指定本地数据文件（silentnotes_repository.silentnotes）的保存目录"
                 IsReadOnly="True"
                 Background="{DynamicResource SilentNotesAccentSoftBrush}"
                 TextWrapping="NoWrap" />
        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
          <Button x:Name="BrowseDataDirButton"
                  Content="选择文件夹..."
                  MinWidth="90"
                  Click="BrowseDataDirButton_Click" />
          <Button x:Name="ResetDataDirButton"
                  Content="恢复默认"
                  MinWidth="80"
                  Margin="8,0,0,0"
                  Click="ResetDataDirButton_Click" />
        </StackPanel>

      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,16,0,0">
      <Button x:Name="TestConnectionButton"
              Content="测试连接"
              MinWidth="80"
              IsEnabled="False"
              Click="TestConnectionButton_Click" />
      <Button x:Name="SaveButton"
              Style="{StaticResource PrimaryButtonStyle}"
              Content="保存"
              MinWidth="80"
              Margin="8,0,0,0"
              Click="SaveButton_Click" />
      <Button Content="取消"
              MinWidth="80"
              Margin="8,0,0,0"
              Click="CancelButton_Click" />
    </StackPanel>
  </Grid>
</controls:ThemedDialogWindow>
