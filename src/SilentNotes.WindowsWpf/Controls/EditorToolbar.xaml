<UserControl x:Class="SilentNotes.WindowsWpf.Controls.EditorToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ToolBar Margin="0,0,0,14">
    <Button ToolTip="撤销 (Ctrl+Z)" MinWidth="32" Padding="4" Click="UndoButton_Click">
      <Viewbox Width="16" Height="16">
        <Canvas Width="24" Height="24">
          <Path Data="M12.5,8C9.85,8 7.45,9 5.6,10.6L2,7V16H11L7.38,12.38C8.77,11.22 10.54,10.5 12.5,10.5C16.04,10.5 19.05,12.81 20.1,16L22.47,15.22C21.08,11.03 17.15,8 12.5,8Z"
                Fill="{DynamicResource SilentNotesTextBrush}" />
        </Canvas>
      </Viewbox>
    </Button>
    <Button ToolTip="重做 (Ctrl+Y)" MinWidth="32" Padding="4" Click="RedoButton_Click">
      <Viewbox Width="16" Height="16">
        <Canvas Width="24" Height="24">
          <Path Data="M18.4,10.6C16.55,9 14.15,8 11.5,8C6.85,8 2.92,11.03 1.54,15.22L3.9,16C4.95,12.81 7.95,10.5 11.5,10.5C13.45,10.5 15.23,11.22 16.62,12.38L13,16H22V7L18.4,10.6Z"
                Fill="{DynamicResource SilentNotesTextBrush}" />
        </Canvas>
      </Viewbox>
    </Button>
    <Separator />
    <Button Content="H1" Click="Heading1Button_Click" ToolTip="标题 1" FontWeight="Bold" MinWidth="32" />
    <Button Content="H2" Click="Heading2Button_Click" ToolTip="标题 2" FontWeight="Bold" MinWidth="32" />
    <Button Content="H3" Click="Heading3Button_Click" ToolTip="标题 3" FontWeight="Bold" MinWidth="32" />
    <Separator />
    <Button Content="粗体" Click="BoldButton_Click" />
    <Button Content="斜体" Click="ItalicButton_Click" />
    <Button Content="下划线" Click="UnderlineButton_Click" />
    <Button Content="删除线" Click="StrikethroughButton_Click" />
    <Separator />
    <Button Content="项目符号" Click="BulletsButton_Click" />
    <Button Content="编号" Click="NumberingButton_Click" />
    <Separator />
    <Button Content="引用" Click="BlockquoteButton_Click" />
    <Button Content="代码块" Click="CodeBlockButton_Click" />
    <Button Content="分割线" Click="HorizontalRuleButton_Click" />
    <Separator />
    <Button Content="链接" Click="LinkButton_Click" />
    <Separator />
    <CheckBox x:Name="PinnedCheckBox"
              Content="置顶"
              VerticalAlignment="Center"
              Margin="4,0"
              ToolTip="将笔记置顶显示"
              Checked="PinnedCheckBox_Changed"
              Unchecked="PinnedCheckBox_Changed" />
  </ToolBar>
</UserControl>
