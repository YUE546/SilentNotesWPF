<UserControl x:Class="SilentNotes.WindowsWpf.Views.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{DynamicResource SilentNotesPanelBrush}"
          Padding="12,12,12,8">
    <DockPanel>
      <!-- Bottom action buttons (single row) -->
      <StackPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
        <!-- Active mode: one row with all buttons -->
        <StackPanel x:Name="ActiveModeButtons" Orientation="Horizontal" HorizontalAlignment="Center">
          <Button x:Name="NewNoteButton"
                  Style="{StaticResource PrimaryButtonStyle}"
                  Content="+ 新建"
                  MinWidth="56"
                  FontSize="12"
                  Click="NewNoteButton_Click" />
          <Button x:Name="NewChecklistButton"
                  Content="清单"
                  MinWidth="44"
                  Margin="4,0,0,0"
                  FontSize="12"
                  Click="NewChecklistButton_Click" />
          <Button x:Name="DeleteNoteButton"
                  ToolTip="移到回收站"
                  MinWidth="32"
                  Margin="4,0,0,0"
                  Padding="4"
                  Click="DeleteNoteButton_Click">
            <Viewbox Width="18" Height="18">
              <Canvas Width="24" Height="24">
                <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                      Fill="{DynamicResource SilentNotesDangerBrush}" />
              </Canvas>
            </Viewbox>
          </Button>
        </StackPanel>
        <!-- Recycle bin mode: one row -->
        <StackPanel x:Name="RecycleBinModeButtons" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="Collapsed">
          <Button x:Name="RestoreNoteButton"
                  Content="恢复"
                  MinWidth="48"
                  FontSize="12"
                  Click="RestoreNoteButton_Click" />
          <Button x:Name="PermanentDeleteNoteButton"
                  ToolTip="永久删除"
                  MinWidth="32"
                  Margin="4,0,0,0"
                  Padding="4"
                  Click="PermanentDeleteNoteButton_Click">
            <Viewbox Width="18" Height="18">
              <Canvas Width="24" Height="24">
                <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                      Fill="{DynamicResource SilentNotesDangerBrush}" />
              </Canvas>
            </Viewbox>
          </Button>
          <Button x:Name="EmptyRecycleBinButton"
                  Style="{StaticResource DangerButtonStyle}"
                  Content="清空"
                  MinWidth="48"
                  Margin="4,0,0,0"
                  FontSize="12"
                  Click="EmptyRecycleBinButton_Click" />
        </StackPanel>
      </StackPanel>

      <!-- Title -->
      <TextBlock x:Name="ListTitleText"
                 DockPanel.Dock="Top"
                 Text="笔记列表"
                 Style="{StaticResource SectionTitleTextStyle}"
                 Margin="0,0,0,6" />

      <!-- Mode tabs: Active / Recycle bin -->
      <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
        <Button x:Name="ActiveNotesButton"
                Style="{StaticResource SegmentButtonStyle}"
                Content="活动笔记"
                Margin="0,0,6,0"
                Click="ActiveNotesButton_Click" />
        <Button x:Name="RecycleBinButton"
                Style="{StaticResource SegmentButtonStyle}"
                Content="回收站"
                Click="RecycleBinButton_Click" />
      </StackPanel>

      <!-- Summary -->
      <TextBlock x:Name="RepositorySummaryText"
                 DockPanel.Dock="Top"
                 Margin="0,0,0,6"
                 Style="{StaticResource SecondaryTextStyle}"
                 TextWrapping="Wrap"
                 FontSize="11" />

      <!-- Search -->
      <TextBox x:Name="SearchTextBox"
               DockPanel.Dock="Top"
               Margin="0,0,0,6"
               FontSize="12"
               Height="28"
               TextChanged="SearchTextBox_TextChanged"
               ToolTip="按标题或正文搜索" />

      <!-- Tag filter: horizontal scrollable with tag icon -->
      <ScrollViewer DockPanel.Dock="Top"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled"
                    Margin="0,0,0,6">
        <StackPanel x:Name="TagPanel"
                    Orientation="Horizontal"
                    Background="Transparent" />
      </ScrollViewer>

      <!-- Note list -->
      <ListBox x:Name="NotesList"
               SelectionChanged="NotesList_SelectionChanged"
               BorderThickness="0"
               Background="Transparent"
               ScrollViewer.VerticalScrollBarVisibility="Auto">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid Margin="0,1">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <TextBlock Grid.Row="0"
                         Text="{Binding Title}"
                         TextTrimming="CharacterEllipsis"
                         FontSize="13"
                         FontWeight="Medium"
                         Foreground="{DynamicResource SilentNotesPrimaryTextBrush}" />
              <TextBlock Grid.Row="1"
                         Text="{Binding BodyLine}"
                         TextTrimming="CharacterEllipsis"
                         FontSize="11"
                         Foreground="{DynamicResource SilentNotesSecondaryTextBrush}"
                         Margin="0,1,0,0"
                         Visibility="{Binding BodyLine, Converter={StaticResource NullToCollapsedConverter}}" />
              <TextBlock Grid.Row="2"
                         Text="{Binding SecondaryLine}"
                         FontSize="10"
                         Foreground="{DynamicResource SilentNotesSecondaryTextBrush}"
                         Margin="0,1,0,0" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <!-- Empty state -->
      <TextBlock x:Name="EmptyListText"
                 DockPanel.Dock="Top"
                 Text="没有匹配的笔记。"
                 Style="{StaticResource SecondaryTextStyle}"
                 TextAlignment="Center"
                 Margin="0,20,0,0"
                 Visibility="Collapsed" />
    </DockPanel>
  </Border>
</UserControl>
