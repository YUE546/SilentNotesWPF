<UserControl x:Class="SilentNotes.WindowsWpf.Views.NoteEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SilentNotes.WindowsWpf.Controls">
  <Border Background="{DynamicResource SilentNotesPaperBrush}"
          Padding="20">
    <DockPanel>
      <StackPanel DockPanel.Dock="Top">
        <TextBlock x:Name="EditorTitleText"
                   Text="编辑器"
                   Style="{StaticResource SectionTitleTextStyle}" />
        <TextBlock x:Name="EditorInfoText"
                   Margin="0,6,0,14"
                   Style="{StaticResource SecondaryTextStyle}"
                   Text="请选择一条笔记。"
                   TextWrapping="Wrap" />
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Text="标签"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"
                     Style="{StaticResource SecondaryTextStyle}" />
          <controls:TagAutoCompleteTextBox x:Name="TagsTextBox"
                                           Grid.Column="1"
                                           ToolTip="输入标签名称，按回车添加"
                                           TagAdded="TagsTextBox_TagAdded"
                                           LostFocus="TagsTextBox_LostFocus" />
          <CheckBox x:Name="DeleteCheckBox"
                    Grid.Column="2"
                    Margin="12,0,0,0"
                    Content="删除"
                    VerticalAlignment="Center"
                    ToolTip="勾选后按回车可删除输入框中的标签"
                    Checked="DeleteCheckBox_Changed"
                    Unchecked="DeleteCheckBox_Changed" />
        </Grid>
        <controls:EditorToolbar x:Name="Toolbar" />
      </StackPanel>
      <RichTextBox x:Name="Editor"
                   AcceptsTab="True"
                   IsDocumentEnabled="True"
                   MinHeight="420"
                   FontFamily="Microsoft YaHei UI, Segoe UI" />
    </DockPanel>
  </Border>
</UserControl>
